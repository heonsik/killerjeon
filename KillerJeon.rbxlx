				<int64 name="SourceAssetId">96150583459141</int64>
				<BinaryString name="Tags"></BinaryString>
				<UniqueId name="UniqueId">6e1cd20ae9f8dc620a02403b0000487f</UniqueId>
			</Properties>
			<Item class="ScreenGui" referent="RBXBDE0BB6E8AC344F3813FCB5B0BBD1D56">
				<Properties>
					<bool name="ClipToDeviceSafeArea">true</bool>
					<int name="DisplayOrder">0</int>
					<token name="SafeAreaCompatibility">1</token>
